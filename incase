function simplifyText(){
  const text = document.getElementById('sandboxInput').value.trim();
  if(!text){ alert('Please paste some text first!'); return; }

  const output = document.getElementById('simplifiedOutput');
  output.innerHTML = '<div style="text-align:center;padding:20px;color:var(--text-muted);">✨ Simplifying your text...</div>';
  output.classList.add('show');

  setTimeout(()=>{
    // Split into sentences
    const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
    const mode = state.currentMode;

    // Mode-specific transformations
    let chunks = [];
    if(mode==='adhd'){
      // Short bullets, high contrast
      chunks = sentences.map((s,i)=>({label:`Point ${i+1}`, text:`• ${s.trim()}`}));
    } else if(mode==='dyslexia'){
      // Short sentences, spaced out
      chunks = sentences.map((s,i)=>({label:`Section ${i+1}`, text:s.trim()}));
    } else if(mode==='visual'){
      // Add emojis
      const emojis=['💡','🔑','📌','🎯','⭐','🔍','📚','🧩'];
      chunks = sentences.map((s,i)=>({label:`${emojis[i%emojis.length]} Part ${i+1}`, text:s.trim()}));
    } else if(mode==='autism'){
      // Very clear numbered steps
      chunks = sentences.map((s,i)=>({label:`Step ${i+1}`, text:s.trim()}));
    } else if(mode==='calm'){
      // Calm gentle phrasing
      chunks = sentences.map((s,i)=>({label:`✦ Part ${i+1}`, text:s.trim()}));
    } else {
      chunks = sentences.map((s,i)=>({label:`Part ${i+1}`, text:s.trim()}));
    }

    output.innerHTML = `
      <div style="font-weight:800;font-size:14px;margin-bottom:14px;color:var(--accent);">✅ Simplified into ${chunks.length} clear parts (${mode} mode):</div>
      ${chunks.map(c=>`
        <div class="simplified-block">
          <div class="part-label">${c.label}</div>
          <div class="part-text">${c.text}</div>
          <button class="read-chip" onclick="voiceGuide(\`${c.text.replace(/`/g,"'")}\`)" style="margin-top:8px;">🔊 Read aloud</button>
        </div>
      `).join('')}
      <div style="text-align:center;margin-top:16px;">
        <button class="apply-btn" onclick="document.getElementById('sandboxInput').value='';document.getElementById('simplifiedOutput').innerHTML='';document.getElementById('simplifiedOutput').classList.remove('show');">↺ Try another text</button>
      </div>
    `;
    addXP(15);
  }, 800);
}

