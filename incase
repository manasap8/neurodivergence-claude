    ],
    flashcards:[
      {front:'When did the Industrial Revolution begin?', back:'In Britain around the 1760s — coal, steam and machines changed everything.'},
      {front:'What years did World War I last?', back:'1914 to 1918 — fought mainly in Europe, killing over 17 million people.'},
      {front:'What years did World War II last?', back:'1939 to 1945 — the deadliest conflict in history (over 70 million deaths).'},
      {front:'What is the Renaissance?', back:'A great rebirth of art, science and learning in Europe (14th–17th centuries).'},
