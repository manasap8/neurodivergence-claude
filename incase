/* ======================================================
   CHUNK RENDER — FIX: visual mode shows visuals
====================================================== */
function renderChunk(idx){
  const data = state.lessonData;
  const chunk = data.chunks[idx];
  const area = document.getElementById('chunkArea');
  if(!area || !chunk) return;

  let html = `<div class="content-chunk ${chunk.type==='key'?'highlight':''}">`;
  html += `<h3>${chunk.heading}</h3>`;
  html += `<p>${chunk.text}</p>`;

  // Visual card — ALWAYS show in visual mode, show if chunk has visual
  if(chunk.visual){
    html += `<div class="visual-card">
      <span class="visual-icon">${chunk.visual.icon}</span>
      <div class="visual-caption">${chunk.visual.caption}</div>
    </div>`;
  } else if(state.currentMode==='visual'){
    // Generate contextual emoji visual for visual mode
    const iconMap = {intro:'🔭🌟📖', key:'⚡🔑💡', text:'📝🔍✏️', visual:'🖼️🎨📊'};
    html += `<div class="visual-card">
      <span class="visual-icon">${iconMap[chunk.type]||'🌟'}</span>
      <div class="visual-caption">Visual summary: ${chunk.heading.replace(/[^a-zA-Z0-9 ]/g,'')}</div>
    </div>`;
  }

  if(chunk.note){
    html += `<div class="inline-note">${chunk.note}</div>`;
  }

  html += `<button class="read-chip" onclick="voiceGuide(\`${chunk.text.replace(/<[^>]+>/g,'').replace(/`/g,"'")}\`)">🔊 Read this section</button>`;
  html += `</div>`;

  if(state.chunkMode){
    area.innerHTML = html;
  } else {
    if(idx===0) area.innerHTML='';
    area.innerHTML += html;
  }

  // Update progress
  const pct = ((idx+1)/data.chunks.length)*100;
  const pb = document.getElementById('chunkProg');
  if(pb) pb.style.width = pct+'%';
  const pl = document.getElementById('chunkLbl');
  if(pl) pl.textContent = `${idx+1}/${data.chunks.length}`;
  const ci = document.getElementById('chunkInfo');
  if(ci) ci.textContent = `Section ${idx+1} of ${data.chunks.length}`;

  // Nav
  const prev = document.getElementById('chunkPrevBtn');
  const next = document.getElementById('chunkNextBtn');
  if(prev) prev.style.display = idx>0?'flex':'none';
  if(next) next.textContent = idx<data.chunks.length-1?'Next Section →':'Go to Flashcards 🃏';

  addXP(5);
}

function nextChunk(){
  const data = state.lessonData;
  if(state.chunkIndex < data.chunks.length-1){
    state.chunkIndex++;
    renderChunk(state.chunkIndex);
  } else {
    showSection('flashcards');
  }
}

function prevChunk(){
  if(state.chunkIndex>0){
    state.chunkIndex--;
    renderChunk(state.chunkIndex);
  }
}

function showSection(sec){
  const fs = document.getElementById('section-flashcards');
  const qs = document.getElementById('section-quiz');
  if(fs) fs.style.display = sec==='flashcards'?'block':'none';
  if(qs) qs.style.display = sec==='quiz'?'block':'none';
  if(sec==='flashcards') renderFlashcard();
  if(sec==='quiz') loadQuiz();
  // scroll into view
  const el = document.getElementById('section-'+sec);
  if(el) el.scrollIntoView({behavior:'smooth', block:'start'});
}

/* ======================================================
   FLASHCARDS — FIX: lesson-specific questions + colour
====================================================== */
function loadFlashcards(){
  state.flashcardIndex = 0;
  renderFlashcard();
}

function renderFlashcard(){
  const cards = state.lessonData && state.lessonData.flashcards;
  if(!cards || !cards.length) return;
  const idx = state.flashcardIndex;
  const el = document.getElementById('flashcard');
  if(!el) return;
  el.classList.remove('flipped');
  document.getElementById('fcFront').textContent = cards[idx].front;
  document.getElementById('fcBack').textContent = cards[idx].back;
  document.getElementById('fcCounter').textContent = `${idx+1} / ${cards.length}`;
}

function flipFlashcard(){
  const el = document.getElementById('flashcard');
  if(!el) return;
  el.classList.toggle('flipped');
  if(el.classList.contains('flipped')) addXP(2);
}

function fcNav(dir){
  const cards = state.lessonData.flashcards;
  state.flashcardIndex = Math.max(0, Math.min(cards.length-1, state.flashcardIndex+dir));
  renderFlashcard();
}

/* ======================================================
   QUIZ — FIX: 4 questions, topic-specific
====================================================== */
function loadQuiz(){
  const quizzes = state.lessonData.quiz;
  state.quizAnswers = {};
  state.quizTotal = quizzes.length;
  const area = document.getElementById('quizArea');
  const complete = document.getElementById('quizComplete');
  if(complete) complete.style.display='none';

  area.innerHTML = quizzes.map((q,qi)=>`
    <div class="quiz-card" id="qc-${qi}">
      <h3>Q${qi+1}. ${q.q}</h3>
      <div class="quiz-options">
        ${q.options.map((opt,oi)=>`
          <button class="quiz-option" id="qo-${qi}-${oi}" onclick="answerQuiz(${qi},${oi})">
            ${String.fromCharCode(65+oi)}. ${opt}
          </button>
        `).join('')}
      </div>
      <div class="quiz-feedback" id="qfb-${qi}"></div>
    </div>
  `).join('');
}

function answerQuiz(qi, oi){
  if(state.quizAnswers[qi]!==undefined) return;
  const quizzes = state.lessonData.quiz;
  const correct = quizzes[qi].answer;
  state.quizAnswers[qi] = oi;

  const chosen = document.getElementById(`qo-${qi}-${oi}`);
  const correctBtn = document.getElementById(`qo-${qi}-${correct}`);
  const fb = document.getElementById(`qfb-${qi}`);

  document.querySelectorAll(`#qc-${qi} .quiz-option`).forEach(b=>{b.disabled=true;});

  if(oi===correct){
    chosen.classList.add('correct');
    fb.className='quiz-feedback show correct-fb';
    fb.innerHTML=`✅ ${quizzes[qi].explanation}`;
    addXP(20);
    state.quizzesCorrect++;
    saveState();
  } else {
    chosen.classList.add('wrong');
    correctBtn.classList.add('correct');
    fb.className='quiz-feedback show wrong-fb';
    fb.innerHTML=`❌ Not quite! ${quizzes[qi].explanation}`;
  }

  if(Object.keys(state.quizAnswers).length===state.quizTotal){
    setTimeout(()=>{
      const correctCount = Object.entries(state.quizAnswers).filter(([qi,oi])=>quizzes[parseInt(qi)].answer===parseInt(oi)).length;
      document.getElementById('quizScore').textContent = `You got ${correctCount} out of ${state.quizTotal} correct! 🎉`;
      document.getElementById('quizComplete').style.display='block';
      confetti();
    }, 800);
  }
}

function markChapterDone(){
  const ch = state.currentSubject.chapters[state.currentChapterIndex];
  if(!ch.done){
    ch.done = true;
    state.lessonsCompleted++;
    addXP(50);
    // Update streak — FIX: proper streak counting
    const today = new Date().toDateString();
    if(state.lastStudyDate !== today){
      const yesterday = new Date();
      yesterday.setDate(yesterday.getDate()-1);
      if(state.lastStudyDate === yesterday.toDateString()){
        state.streak++; // continuing streak
      } else if(!state.lastStudyDate){
        state.streak = 1; // first time
      } else {
        state.streak = 1; // streak broken, reset to 1
      }
      state.lastStudyDate = today;
    }
    updateStreakUI();
    saveState();
  }
  renderSidebar(state.currentSubject, state.currentChapterIndex);
  const cc = document.getElementById('chapterComplete');
  if(cc){ cc.style.display='block'; cc.scrollIntoView({behavior:'smooth',block:'center'}); }
  showReward('🏆','Chapter Complete!',`+50 XP earned! Streak: ${state.streak} 🔥`);
  confetti();
}

/* ======================================================
   WORD DEFINITIONS — FIX: global click handler
====================================================== */
document.body.addEventListener('click', e=>{
  if(!state.wordDefEnabled) return;
  const el = e.target.closest('.key-word');
  if(!el) return;
  const def = el.dataset.def;
  if(!def) return;
  const tt = document.getElementById('wordTooltip');
  tt.textContent = def;
  tt.style.left = (e.clientX+14)+'px';
  tt.style.top = Math.max(10, e.clientY-50)+'px';
  tt.classList.add('show');
  clearTimeout(tt._timer);
  tt._timer = setTimeout(()=>tt.classList.remove('show'), 3500);
});

/* ======================================================
   TEXT TO SPEECH
====================================================== */
function voiceGuide(text){
  if(!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const u = new SpeechSynthesisUtterance(text);
  u.rate = 0.88; u.pitch = 1;
  window.speechSynthesis.speak(u);
}

function toggleTTS(toggle){
  toggle.classList.toggle('on');
  state.ttsEnabled = toggle.classList.contains('on');
  document.getElementById('ttsBar').style.display =
    (state.ttsEnabled && document.getElementById('page-lesson').classList.contains('active')) ? 'flex':'none';
  saveState();
}

function toggleTTSRead(){
  if(state.isSpeaking){ ttsStop(); } else { ttsReadPage(); }
}

function ttsReadPage(){
  if(!window.speechSynthesis){ alert('Text-to-speech not supported.'); return; }
  window.speechSynthesis.cancel();
  const ps = document.querySelectorAll('#chunkArea p');
  const text = Array.from(ps).map(p=>p.innerText).join(' ');
  if(!text) return;
  const u = new SpeechSynthesisUtterance(text);
  u.rate = 0.85; u.pitch = 1;
  state.isSpeaking = true;
  document.getElementById('ttsStatus').textContent = 'Reading...';
  document.getElementById('ttsPauseBtn').textContent = '⏸ Pause';
  u.onend = ()=>{ state.isSpeaking=false; document.getElementById('ttsStatus').textContent='Done ✓'; };
  window.speechSynthesis.speak(u);
}

function ttsPause(){
  if(window.speechSynthesis.paused){ window.speechSynthesis.resume(); document.getElementById('ttsPauseBtn').textContent='⏸ Pause'; }
  else { window.speechSynthesis.pause(); document.getElementById('ttsPauseBtn').textContent='▶ Resume'; }
}

function ttsStop(){
  window.speechSynthesis.cancel();
  state.isSpeaking = false;
  document.getElementById('ttsStatus').textContent='';
}

/* ======================================================
   POMODORO TIMER — FIX: no auto-start, proper state
====================================================== */
function setPomoDuration(mins){
  state.pomoDuration = mins;
  if(!state.pomoRunning) state.pomoSecondsLeft = mins*60;
  renderPomoTime();
  saveState();
}

function pomoToggle(){
  if(state.pomoRunning){
    // Pause
    clearInterval(state.pomoTimerID);
    state.pomoTimerID = null;
    state.pomoRunning = false;
    document.getElementById('pomoBtnStart').textContent = '▶ Resume';
  } else {
    // Start/Resume
    state.pomoRunning = true;
    document.getElementById('pomoBtnStart').textContent = '⏸ Pause';
    state.pomoTimerID = setInterval(()=>{
      state.pomoSecondsLeft--;
      renderPomoTime();
      if(state.pomoSecondsLeft<=0){
        clearInterval(state.pomoTimerID);
        state.pomoTimerID = null;
        state.pomoRunning = false;
        state.pomoSessions++;
        document.getElementById('pomoBtnStart').textContent = '▶ Start';
        const isLong = state.pomoSessions%3===0;
        showReward('⏰','Session Done!', isLong?'Take a 15 min break! 🌟':'Take a 5 min break!');
        if(state.voiceGuideEnabled) voiceGuide(isLong?'Excellent! Take a longer break.':'Session done! Short break time.');
        pomoReset(true);
      }
    },1000);
  }
}

function pomoReset(keepSessions){
  clearInterval(state.pomoTimerID);
  state.pomoTimerID = null;
  state.pomoRunning = false;
  state.pomoSecondsLeft = state.pomoDuration*60;
  if(!keepSessions) state.pomoSessions = 0;
  document.getElementById('pomoBtnStart').textContent = '▶ Start';
  renderPomoTime();
  renderPomoDots();
}

function renderPomoTime(){
  const m = Math.floor(state.pomoSecondsLeft/60);
  const s = state.pomoSecondsLeft%60;
  const el = document.getElementById('pomodoroTime');
  if(el) el.textContent = `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  // Ring
  const total = state.pomoDuration*60;
  const prog = (total-state.pomoSecondsLeft)/total;
  const circ = 2*Math.PI*57;
  const ring = document.getElementById('ringProgress');
  if(ring) ring.style.strokeDashoffset = circ*(1-prog);
}

function renderPomoDots(){
  const el = document.getElementById('pomoDots');
  if(!el) return;
  el.innerHTML = [0,1,2].map(i=>`<div class="pomo-dot ${i<(state.pomoSessions%3)?'done':''}"></div>`).join('');
}

/* ======================================================
   DASHBOARD
====================================================== */
function renderDashboard(){
  document.getElementById('stat-lessons').textContent = state.lessonsCompleted;
  document.getElementById('stat-xp').textContent = state.xp;
  document.getElementById('stat-quizzes').textContent = state.quizzesCorrect;
  document.getElementById('stat-streak').textContent = state.streak;

  const sp = document.getElementById('subjectProgress');
  sp.innerHTML = SUBJECTS.map(s=>{
    const done = s.chapters.filter(c=>c.done).length;
    const pct = Math.round(done/s.chapters.length*100);
    return `
      <div style="margin-bottom:14px;">
        <div style="display:flex;justify-content:space-between;font-size:14px;font-weight:700;margin-bottom:5px;">
          <span>${s.icon} ${s.title}</span>
          <span style="color:var(--text-muted)">${done}/${s.chapters.length}</span>
        </div>
        <div style="height:9px;background:var(--surface2);border-radius:5px;overflow:hidden;">
          <div style="width:${pct}%;height:100%;background:${s.color};border-radius:5px;transition:width 0.5s;"></div>
        </div>
      </div>`;
  }).join('');

  // Show timer state without auto-starting
  renderPomoTime();
  renderPomoDots();
  const startBtn = document.getElementById('pomoBtnStart');
  if(startBtn) startBtn.textContent = state.pomoRunning ? '⏸ Pause' : (state.pomoSecondsLeft<state.pomoDuration*60 ? '▶ Resume' : '▶ Start');

  setTimeout(()=>{
    if(window.mermaid){
      mermaid.initialize({startOnLoad:false, theme:'default', securityLevel:'loose'});
      mermaid.init(undefined, '.mermaid');
    }
  }, 200);
}

/* ======================================================
   SETTINGS SYNC
====================================================== */
function syncSettings(){
  const ids = {ttsToggle:'ttsEnabled', wordDefToggle:'wordDefEnabled', voiceGuideToggle:'voiceGuideEnabled',
    animToggle:'no_animation', chunkToggle:'chunkMode'};
  Object.entries(ids).forEach(([id, key])=>{
    const el = document.getElementById(id);
    if(!el) return;
    if(key==='no_animation') el.classList.toggle('on', document.body.classList.contains('no-animation'));
    else el.classList.toggle('on', !!state[key]);
  });
  const ms = document.getElementById('modeSelect');
  if(ms) ms.value = state.currentMode;
  const pd = document.getElementById('pomoDurationSelect');
  if(pd) pd.value = state.pomoDuration;
}

function toggleClass(el, cls){ el.classList.toggle(cls); }

function saveSettings(){
  saveState();
  showReward('💾','Settings Saved!','Your preferences are updated');
}

/* ======================================================
   XP
====================================================== */
function addXP(n){
  state.xp += n;
  const xb = document.getElementById('xpBar');
  const xn = document.getElementById('xpNum');
  if(xb) xb.style.width = (state.xp%100)+'%';
  if(xn) xn.textContent = state.xp;
  saveState();
}

