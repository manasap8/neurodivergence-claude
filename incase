  /* ---- ENGLISH ---- */
  grammar:{
    title:'Grammar Basics', readTime:'9 min',
    chunks:[
      {type:'intro', heading:'📝 What is Grammar?',
       text:`<span class="key-word" data-def="The set of rules that governs how words work together in a language">Grammar</span> is the rulebook of language. When we follow grammar, other people can understand us clearly. Without grammar, sentences become confusing!`,
       visual:{icon:'📖✏️🗣️', caption:'Good grammar makes communication clear and powerful'}},
      {type:'key', heading:'🔤 The 8 Parts of Speech',
       text:`Words have jobs: A <span class="key-word" data-def="A word that names a person, place, thing or idea — 'dog', 'school', 'love'">noun</span> names things. A <span class="key-word" data-def="A word that shows action or state — 'run', 'is', 'think'">verb</span> shows action. An <span class="key-word" data-def="Describes a noun — 'big', 'happy', 'red'">adjective</span> describes nouns. An <span class="key-word" data-def="Describes a verb — 'quickly', 'very', 'carefully'">adverb</span> describes verbs. A <span class="key-word" data-def="Takes the place of a noun — 'he', 'she', 'they', 'it'">pronoun</span> replaces a noun.`,
       note:'💡 Every word in English belongs to one of 8 categories called Parts of Speech.'},
      {type:'visual', heading:'📐 Building a Sentence',
       text:`Every sentence needs: a <strong>Subject</strong> (who/what does it) + a <strong>Verb</strong> (what they do) + optional <strong>Object</strong>. Example: "The dog [subject] ate [verb] a biscuit [object]."`,
       visual:{icon:'👤 + ⚡ + 🎯', caption:'Subject + Verb + Object = A complete sentence!'}},
      {type:'text', heading:'❓ Punctuation',
       text:`<span class="key-word" data-def="A full stop (.) used at the end of a sentence">Full stops</span>, <span class="key-word" data-def="A question mark (?) used at the end of a question">question marks</span>, and <span class="key-word" data-def="An exclamation mark (!) used to show excitement or strong feeling">exclamation marks</span> end sentences. <span class="key-word" data-def="A comma (,) creates a pause within a sentence">Commas</span> create pauses. Capitals start sentences and proper nouns.`}
    ],
    flashcards:[
      {front:'What is a noun?', back:'A word that names a person, place, thing or idea. Examples: "dog", "city", "happiness."'},
      {front:'What is a verb?', back:'A word that shows an action or state. Examples: "run", "is", "think", "jump."'},
      {front:'What is an adjective?', back:'A word that describes a noun. Examples: "big", "happy", "red", "fast."'},
      {front:'What is an adverb?', back:'A word that describes a verb. Examples: "quickly", "carefully", "very", "today."'},
      {front:'What does a sentence need minimum?', back:'A subject (who/what) and a verb (what they do). E.g., "Birds fly."'}
    ],
    quiz:[
      {q:'Which word is a NOUN in: "The clever dog barked loudly"?',
       options:['clever','barked','dog','loudly'],
       answer:2, explanation:'"Dog" is a noun — it names the animal (a thing). "Clever" is adjective, "barked" is verb, "loudly" is adverb.'},
      {q:'Which word is a VERB in: "She quickly painted the wall"?',
       options:['quickly','She','wall','painted'],
       answer:3, explanation:'"Painted" is the verb — it shows the action that happened.'},
      {q:'What does an adjective describe?',
       options:['A verb','A pronoun','A noun','An adverb'],
       answer:2, explanation:'Adjectives describe nouns — e.g., "big dog" (big describes dog).'},
      {q:'Which is a PRONOUN in: "She gave him the book"?',
       options:['gave','book','She','the'],
       answer:2, explanation:'"She" is a pronoun — it replaces a person\'s name and takes the place of a noun.'}
    ]
  },

  reading:{
    title:'Reading Comprehension', readTime:'8 min',
    chunks:[
      {type:'intro', heading:'📖 What is Comprehension?',
       text:`<span class="key-word" data-def="The ability to read text and understand its meaning, not just the words">Reading comprehension</span> means truly understanding what you read — not just recognising the words. It involves finding the <span class="key-word" data-def="The most important idea the author wants to communicate">main idea</span> and supporting details.`,
       visual:{icon:'👁️📄💡', caption:'Good readers actively think about what they are reading'}},
      {type:'key', heading:'🔍 Finding the Main Idea',
       text:`The <span class="key-word" data-def="The central point or most important idea of a text">main idea</span> is what a paragraph is mainly about. <span class="key-word" data-def="Smaller pieces of information that support and explain the main idea">Supporting details</span> give evidence. Ask yourself: "What is this passage mainly talking about?"`,
       note:'💡 The main idea is often in the first or last sentence of a paragraph.'},
      {type:'visual', heading:'📝 Types of Questions',
       text:`Comprehension questions can be: <strong>Literal</strong> (the answer is directly stated), <strong>Inferential</strong> (you must work it out from clues), or <strong>Evaluative</strong> (your opinion with reasons).`,
       visual:{icon:'❓📝🤔', caption:'Three types of comprehension questions — from simple to complex'}},
      {type:'text', heading:'🗝️ Reading Strategies',
       text:`Good readers: <span class="key-word" data-def="Read a text again to better understand or find specific information">re-read</span> confusing parts, look at <span class="key-word" data-def="Visual clues like pictures, headings and diagrams that help understanding">context clues</span>, break <span class="key-word" data-def="Words you don't know — break them into parts to figure out meaning">unfamiliar words</span> into parts, and summarise in their own words.`}
    ],
    flashcards:[
      {front:'What is the main idea?', back:'The most important or central point of a text — what it is mainly about.'},
      {front:'What are supporting details?', back:'Facts, examples or reasons that support and explain the main idea.'},
      {front:'What is a literal question?', back:'A question whose answer is directly stated in the text (just find and read it!).'},
      {front:'What is an inferential question?', back:'A question where you must use clues in the text to figure out the answer.'},
      {front:'Name 2 good reading strategies', back:'Re-reading confusing parts AND looking for context clues around unknown words.'}
    ],
    quiz:[
      {q:'What does reading comprehension mean?',
       options:['Reading very fast','Memorising every word','Truly understanding what you read','Counting the words'],
       answer:2, explanation:'Comprehension means understanding the meaning, ideas and purpose of a text.'},
      {q:'Where is the main idea often found?',
       options:['In the middle of every paragraph','Only at the end of the whole text','In the first or last sentence of a paragraph','In pictures'],
       answer:2, explanation:'Authors often state the main idea at the start or end of a paragraph as a topic sentence.'},
      {q:'What is a literal question?',
       options:['One you must guess','One whose answer is directly in the text','One about your opinion','One about pictures'],
       answer:1, explanation:'Literal questions have answers directly stated in the text — you just need to find them.'},
      {q:'What is an inferential question?',
       options:['A question about numbers','A question directly answered in the text','A question where you use clues to figure out the answer','A question about grammar'],
       answer:2, explanation:'Inferential questions need you to "read between the lines" using clues and prior knowledge.'}
    ]
  },

  writing:{
    title:'Creative Writing', readTime:'8 min',
    chunks:[
      {type:'intro', heading:'✍️ What is Creative Writing?',
       text:`<span class="key-word" data-def="Writing that uses imagination, characters, and storytelling to express ideas and emotions">Creative writing</span> is telling stories. It includes fiction, poetry, screenplays, and personal narratives. Good writing makes readers feel, think, and imagine.`,
       visual:{icon:'✍️📖🌟', caption:'Creative writing brings ideas to life through words'}},
      {type:'key', heading:'📖 Story Structure',
       text:`Most stories follow a structure: <span class="key-word" data-def="Introduces the setting, characters, and situation at the start of a story">Introduction</span> → <span class="key-word" data-def="Events that build tension and lead toward the main problem">Rising Action</span> → <span class="key-word" data-def="The most exciting or tense moment of the story">Climax</span> → <span class="key-word" data-def="Events after the climax where problems start to be solved">Falling Action</span> → <span class="key-word" data-def="The ending where conflicts are resolved">Resolution</span>.`,
       note:'📐 This story shape is called a "narrative arc" — used in most books, films and games!'},
      {type:'visual', heading:'🎭 Characters & Setting',
       text:`A <span class="key-word" data-def="A person or creature in a story whose actions and choices drive the plot">character</span> is who your story is about. The <span class="key-word" data-def="Where and when a story takes place — time period and location">setting</span> is where and when. Use specific details to make both feel real to the reader.`,
       visual:{icon:'🧍🏫🌌', caption:'Strong characters + vivid settings = unforgettable stories'}},
      {type:'text', heading:'🌈 Show, Don\'t Tell',
       text:`The golden rule: <em>show</em> feelings through actions instead of <em>telling</em>. Instead of "She was scared," write "Her hands trembled as she reached for the handle." This uses <span class="key-word" data-def="Words that appeal to the five senses — sight, sound, smell, taste, touch">sensory language</span>.`}
    ],
    flashcards:[
      {front:'What are the 5 parts of story structure?', back:'Introduction → Rising Action → Climax → Falling Action → Resolution.'},
      {front:'What is the climax?', back:'The most exciting/tense moment of the story — the turning point.'},
      {front:'What is a setting?', back:'Where and when a story takes place — the time and location.'},
      {front:'What does "show, don\'t tell" mean?', back:'Show emotions through actions and sensory details instead of just stating them.'},
      {front:'What is sensory language?', back:'Words that appeal to the 5 senses (sight, sound, smell, taste, touch) to make writing vivid.'}
    ],
    quiz:[
      {q:'What is the climax of a story?',
       options:['The boring middle part','The very beginning','The most exciting/tense moment','The last sentence'],
       answer:2, explanation:'The climax is the highest point of tension — the turning point where everything changes.'},
      {q:'What does "setting" mean in a story?',
       options:['The main character\'s name','Where and when the story takes place','The moral lesson','The title'],
       answer:1, explanation:'Setting is the time and place of a story — e.g., "Victorian London" or "a spaceship in 3050."'},
      {q:'What does "Show, don\'t tell" mean?',
       options:['Use pictures instead of words','Describe emotions through actions and senses, not labels','Only use dialogue','Write very short stories'],
       answer:1, explanation:'Instead of "She was sad" (telling), write "Tears ran down her cheeks" (showing).'},
      {q:'Which part of story structure comes FIRST?',
       options:['Climax','Falling Action','Resolution','Introduction'],
       answer:3, explanation:'The Introduction (or Exposition) comes first — it sets the scene, characters and situation.'}
    ]
  },

  /* ---- COMPUTER SCIENCE ---- */
  'computer-basics':{
    title:'What is a Computer?', readTime:'7 min',
    chunks:[
      {type:'intro', heading:'💻 What is a Computer?',
       text:`A <span class="key-word" data-def="An electronic device that processes data according to instructions and stores information">computer</span> is an electronic machine that stores, processes, and outputs information. Computers follow detailed instructions called <span class="key-word" data-def="A set of step-by-step instructions that tell a computer what to do">programs</span> (or software).`,
       visual:{icon:'💻🖥️📱', caption:'Computers come in many forms — laptops, desktops, tablets, phones'}},
      {type:'key', heading:'🧩 Key Hardware Parts',
       text:`The <span class="key-word" data-def="Central Processing Unit — the brain of the computer that performs calculations at billions of times per second">CPU</span> is the brain. <span class="key-word" data-def="Random Access Memory — fast, temporary storage the computer uses right now (lost when switched off)">RAM</span> is short-term memory. The <span class="key-word" data-def="Hard Disk Drive or SSD — permanent storage for files, photos, programs (kept when switched off)">Storage Drive</span> keeps files forever. The <span class="key-word" data-def="Graphics Processing Unit — specialised chip that handles images, video and games">GPU</span> handles images.`,
