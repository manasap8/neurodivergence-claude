====================================================== */
function applyMode(mode){
  const body = document.body;
  body.className = body.className.replace(/mode-\S+/g,'').trim();
  if(mode && mode!=='default') body.classList.add('mode-'+mode);
  state.currentMode = mode;
  const ms = document.getElementById('modeSelect');
  if(ms) ms.value = mode;
  if(state.voiceGuideEnabled){
    const msgs={adhd:'ADHD mode. Clean blue focus layout enabled.',
      dyslexia:'Dyslexia mode. Warm background with Atkinson Hyperlegible font.',
      autism:'Autism mode. Calm green, consistent and predictable layout.',
      visual:'Visual mode. Dark purple with rich visual emphasis.',
      calm:'Calm mode. Soft sage greens for relaxed pacing.',
      highcontrast:'High contrast mode. Black background with gold text.'};
    if(msgs[mode]) voiceGuide(msgs[mode]);
  }
  saveState();
}

