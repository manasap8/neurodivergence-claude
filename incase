<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NeuroLearn — Adaptive Learning for Everyone</title>
<link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@400;500;600;700;800&family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>
<style>
/* =============================================
   ROOT — Default Mode: Warm Cream & Indigo
============================================= */
:root {
  --bg: #FAF7F2;
  --bg2: #F0EBE1;
  --surface: #FFFFFF;
  --surface2: #EDE8E0;
  --border: #D8D0C4;
  --text: #1C1814;
  --text-muted: #6B6057;
  --accent: #4A5CE8;
  --accent-light: #EEF0FD;
  --accent2: #E8603A;
  --accent3: #2DB89E;
  --accent4: #C062B8;
  --success: #3AAF6B;
  --warning: #F0A020;
  --danger: #E04040;
  --radius: 18px;
  --radius-sm: 10px;
  --shadow: 0 2px 16px rgba(0,0,0,0.07);
  --shadow-lg: 0 8px 40px rgba(0,0,0,0.13);
  --font-size: 16px;
  --line-height: 1.7;
  --letter-spacing: 0.01em;
  --word-spacing: 0;
  --font-body: 'Baloo 2', cursive;
  --font-reading: 'Atkinson Hyperlegible', sans-serif;
  --transition: 0.3s cubic-bezier(0.4,0,0.2,1);
  --nav-h: 66px;
  /* Mode indicator strip color */
  --mode-color: #4A5CE8;
}

/* =============================================
   MODE: ADHD — Clean blue, ultra-minimal
============================================= */
body.mode-adhd {
  --bg: #F0F6FF;
  --bg2: #E3EEFF;
  --surface: #FFFFFF;
  --surface2: #DBE8FF;
  --border: #99B8FF;
  --text: #0D1B3E;
  --text-muted: #4A6096;
  --accent: #2550D9;
  --accent-light: #EAF0FF;
  --accent2: #FF6B35;
  --accent3: #22BB8A;
  --mode-color: #2550D9;
  --font-size: 16px;
  --line-height: 1.6;
}
body.mode-adhd .content-chunk { border-left: 5px solid var(--accent); }
body.mode-adhd .content-chunk p { max-width: 600px; }
body.mode-adhd nav { border-bottom: 3px solid var(--accent); }
body.mode-adhd .mode-strip { background: linear-gradient(90deg, #2550D9, #7B9EFF); }
body.mode-adhd .hero { background: linear-gradient(135deg, #E3EEFF 0%, #F0F6FF 100%); }
body.mode-adhd .subject-card:hover { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(37,80,217,0.18); }

/* =============================================
   MODE: DYSLEXIA — Warm yellow, Atkinson font
============================================= */
body.mode-dyslexia {
  --bg: #FDFAE8;
  --bg2: #F7F0CA;
  --surface: #FFFEF5;
  --surface2: #F2EAC0;
  --border: #D4C46A;
  --text: #2A2000;
  --text-muted: #5A4A00;
  --accent: #005A9C;
  --accent-light: #E0F0FF;
  --accent2: #CC6600;
  --accent3: #007A50;
  --mode-color: #005A9C;
  --font-size: 18px;
  --line-height: 2.0;
  --letter-spacing: 0.04em;
  --word-spacing: 0.1em;
  font-family: 'Atkinson Hyperlegible', sans-serif !important;
}
body.mode-dyslexia * { font-family: 'Atkinson Hyperlegible', sans-serif !important; }
body.mode-dyslexia p, body.mode-dyslexia .content-chunk p { text-align: left !important; max-width: 65ch; }
body.mode-dyslexia .mode-strip { background: linear-gradient(90deg, #005A9C, #4A9ADA); }
body.mode-dyslexia .hero { background: linear-gradient(135deg, #F7F0CA 0%, #FDFAE8 100%); }
body.mode-dyslexia .content-chunk { padding: 28px 32px; }

/* =============================================
   MODE: AUTISM — Muted green, calm, consistent
============================================= */
body.mode-autism {
  --bg: #EDF5EE;
  --bg2: #DFF0E0;
  --surface: #F8FCF8;
  --surface2: #D3ECD5;
  --border: #9DCBA0;
  --text: #102010;
  --text-muted: #3A6040;
  --accent: #2E8B57;
  --accent-light: #E0F5E0;
  --accent2: #5A8B2E;
  --accent3: #2E6B8B;
  --mode-color: #2E8B57;
  --font-size: 16px;
  --line-height: 1.8;
  --shadow: none;
  --shadow-lg: 0 4px 16px rgba(46,139,87,0.12);
}
body.mode-autism * { box-shadow: none !important; }
body.mode-autism .mode-strip { background: linear-gradient(90deg, #2E8B57, #5AB870); }
body.mode-autism .hero { background: linear-gradient(135deg, #DFF0E0 0%, #EDF5EE 100%); }
body.mode-autism nav { border-bottom: 3px solid #9DCBA0; }
body.mode-autism .subject-card { border-radius: 8px; }
body.mode-autism .comfort-card { border-radius: 8px; }

/* =============================================
   MODE: VISUAL — Deep purple, rich imagery
============================================= */
body.mode-visual {
  --bg: #1A0A2E;
  --bg2: #261040;
  --surface: #2A1248;
  --surface2: #341860;
  --border: #6040A0;
  --text: #F0E8FF;
  --text-muted: #B0A0D0;
  --accent: #C080FF;
  --accent-light: #3A2060;
  --accent2: #FF8060;
  --accent3: #60FFD0;
  --accent4: #FFCC40;
  --mode-color: #C080FF;
  --font-size: 16px;
  --line-height: 1.75;
}
body.mode-visual .mode-strip { background: linear-gradient(90deg, #8040C0, #C080FF, #FF8060); }
body.mode-visual .hero { background: linear-gradient(135deg, #261040 0%, #1A0A2E 100%); }
body.mode-visual nav { background: #2A1248; border-bottom: 2px solid #6040A0; }
body.mode-visual .visual-card { background: linear-gradient(135deg, #3A2060, #2A1248); border: 2px solid #C080FF; }
body.mode-visual .visual-card .visual-icon { font-size: 80px; }

/* =============================================
   MODE: CALM — Soft sage, minimal
============================================= */
body.mode-calm {
  --bg: #F2F5F0;
  --bg2: #E8EDE5;
  --surface: #FAFCF9;
  --surface2: #E0E8DC;
  --border: #B8CCAF;
  --text: #1A2215;
  --text-muted: #556050;
  --accent: #6B9BB8;
  --accent-light: #E8F3F8;
  --accent2: #87CEAB;
  --accent3: #B88A6B;
  --mode-color: #6B9BB8;
  --font-size: 16px;
  --line-height: 1.85;
}
body.mode-calm .mode-strip { background: linear-gradient(90deg, #6B9BB8, #87CEAB); }
body.mode-calm .hero { background: linear-gradient(135deg, #E8EDE5 0%, #F2F5F0 100%); }

/* =============================================
   MODE: HIGH CONTRAST — Pure black/white/gold
============================================= */
body.mode-highcontrast {
  --bg: #000000;
  --bg2: #0A0A0A;
  --surface: #111111;
  --surface2: #1C1C1C;
  --border: #555555;
  --text: #FFFFFF;
  --text-muted: #BBBBBB;
  --accent: #FFD700;
  --accent-light: #1A1500;
  --accent2: #00FF99;
  --accent3: #00BFFF;
  --accent4: #FF80C0;
  --mode-color: #FFD700;
}
body.mode-highcontrast .mode-strip { background: linear-gradient(90deg, #FFD700, #FFA500); }
body.mode-highcontrast .hero { background: #111111; }
body.mode-highcontrast nav { background: #000000; border-bottom: 3px solid #FFD700; }
body.mode-highcontrast .key-word { background: #FFD700; color: #000; border-bottom: 2px solid #FFA500; }

/* Font Sizes */
body.font-large { --font-size: 19px; --line-height: 1.85; }
body.font-xlarge { --font-size: 23px; --line-height: 2.0; }
body.no-animation * { animation: none !important; transition: none !important; }

/* =============================================
   RESET & BASE
============================================= */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  font-size: var(--font-size);
  line-height: var(--line-height);
  letter-spacing: var(--letter-spacing);
  word-spacing: var(--word-spacing);
  background: var(--bg);
  color: var(--text);
  transition: background 0.4s, color 0.4s, font-size 0.3s;
  min-height: 100vh;
}

/* =============================================
   MODE STRIP (top indicator bar)
============================================= */
.mode-strip {
  height: 5px;
  background: linear-gradient(90deg, var(--accent), var(--accent3));
  transition: background 0.4s;
}

/* =============================================
   NAV
============================================= */
nav {
  background: var(--surface);
  border-bottom: 2px solid var(--border);
  padding: 0 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: var(--nav-h);
  position: sticky;
  top: 5px;
  z-index: 100;
  box-shadow: var(--shadow);
  transition: background 0.4s, border-color 0.4s;
}

.nav-logo {
  font-family: var(--font-body);
  font-weight: 800;
  font-size: 21px;
  color: var(--accent);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: 8px;
  cursor: pointer;
}
.nav-logo .logo-emoji { font-size: 26px; }

.nav-links { display: flex; gap: 2px; }

.nav-btn {
  background: none;
  border: none;
  padding: 8px 13px;
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.2s;
}
.nav-btn:hover { background: var(--accent-light); color: var(--accent); }
.nav-btn.active { background: var(--accent-light); color: var(--accent); font-weight: 700; }

.nav-right { display: flex; align-items: center; gap: 10px; }

.streak-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: linear-gradient(135deg, #FF6B35, #FF9A00);
  color: white;
  padding: 5px 12px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 700;
}

.focus-mode-btn {
  background: var(--accent);
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 20px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.focus-mode-btn:hover { transform: translateY(-1px); box-shadow: var(--shadow); }

/* EXIT FOCUS button — always rendered, hidden normally */
.exit-focus-btn {
  display: none;
  background: #E04040;
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 20px;
  font-weight: 700;
  font-size: 13px;
  cursor: pointer;
  gap: 5px;
  align-items: center;
  transition: all 0.2s;
}
.exit-focus-btn:hover { background: #C03030; }

/* =============================================
   FOCUS MODE
============================================= */
body.focus-mode nav .nav-links,
body.focus-mode .streak-badge,
body.focus-mode .focus-mode-btn { display: none !important; }
body.focus-mode .exit-focus-btn { display: inline-flex !important; }
body.focus-mode .lesson-sidebar { display: none !important; }
body.focus-mode .lesson-layout { grid-template-columns: 1fr !important; }
body.focus-mode .lesson-content { max-width: 740px; margin: 0 auto; }
body.focus-mode .chatbot-wrap { display: none; }
body.focus-mode .mode-strip { height: 8px; }

/* =============================================
   PAGES
============================================= */
.page { display: none; animation: pageIn 0.25s ease; }
.page.active { display: block; }
@keyframes pageIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

/* =============================================
   HERO
============================================= */
.hero {
  background: var(--surface);
  padding: 56px 24px 44px;
  text-align: center;
  border-bottom: 2px solid var(--border);
  transition: background 0.4s;
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--accent) 8%, transparent) 0%, transparent 70%);
  pointer-events: none;
}

.hero h1 {
  font-size: clamp(28px, 5vw, 50px);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 16px;
  position: relative;
}
.hero h1 em { color: var(--accent); font-style: normal; }

.hero p {
  max-width: 580px;
  margin: 0 auto 28px;
  color: var(--text-muted);
  font-size: clamp(15px, 2.5vw, 18px);
  position: relative;
}

.hero-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
  margin-bottom: 28px;
  position: relative;
}

.badge {
  background: var(--surface2);
  border: 1.5px solid var(--border);
  padding: 5px 13px;
  border-radius: 20px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  transition: all 0.2s;
}
.badge:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-1px); }

.cta-btn {
  background: var(--accent);
  color: white;
  border: none;
  padding: 15px 36px;
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 17px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.25s;
  box-shadow: 0 4px 20px color-mix(in srgb, var(--accent) 40%, transparent);
  position: relative;
}
.cta-btn:hover { transform: translateY(-3px); box-shadow: 0 8px 28px color-mix(in srgb, var(--accent) 50%, transparent); }

/* =============================================
   COMFORT SELECTOR
============================================= */
.comfort-section {
  padding: 44px 24px;
  max-width: 980px;
  margin: 0 auto;
}

.section-title {
  font-size: clamp(20px, 3vw, 28px);
  font-weight: 800;
  margin-bottom: 6px;
}
.section-subtitle { color: var(--text-muted); margin-bottom: 24px; font-size: 15px; }

.comfort-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(185px, 1fr));
  gap: 14px;
  margin-bottom: 28px;
}

.comfort-card {
  background: var(--surface);
  border: 2.5px solid var(--border);
  border-radius: var(--radius);
  padding: 22px 16px;
  cursor: pointer;
  transition: all 0.25s;
  text-align: center;
  user-select: none;
  position: relative;
  overflow: hidden;
}
.comfort-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--accent);
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}
.comfort-card:hover { border-color: var(--accent); transform: translateY(-3px); box-shadow: var(--shadow-lg); }
.comfort-card.selected {
  border-color: var(--accent);
  background: var(--accent-light);
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 22%, transparent);
}
.comfort-card .icon { font-size: 36px; margin-bottom: 10px; display: block; }
.comfort-card .label { font-weight: 800; font-size: 14px; margin-bottom: 5px; }
.comfort-card .desc { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
.comfort-card.selected .desc { color: var(--text); }

/* Mode color dots */
.comfort-card[data-mode="adhd"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #2550D9; border-radius: 4px 4px 0 0; }
.comfort-card[data-mode="dyslexia"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #005A9C; border-radius: 4px 4px 0 0; }
.comfort-card[data-mode="autism"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #2E8B57; border-radius: 4px 4px 0 0; }
.comfort-card[data-mode="visual"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: linear-gradient(90deg,#8040C0,#FF8060); border-radius: 4px 4px 0 0; }
.comfort-card[data-mode="calm"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #6B9BB8; border-radius: 4px 4px 0 0; }
.comfort-card[data-mode="default"]::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px; background: #4A5CE8; border-radius: 4px 4px 0 0; }

.apply-btn {
  background: var(--accent);
  color: white;
  border: none;
  padding: 13px 32px;
  border-radius: 50px;
  font-family: var(--font-body);
  font-size: 16px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  display: block;
  width: fit-content;
  margin: 0 auto;
  box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 35%, transparent);
}
.apply-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 45%, transparent); }

/* Voice chips */
.voice-row { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 24px; }
.voice-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--surface2);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.2s;
}
.voice-chip:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }

/* =============================================
   SUBJECTS GRID
============================================= */
.subjects-section { padding: 36px 24px; max-width: 1120px; margin: 0 auto; }

.subjects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
  gap: 18px;
}

.subject-card {
  background: var(--surface);
  border: 2px solid var(--border);
  border-radius: var(--radius);
  padding: 26px 22px;
  cursor: pointer;
  transition: all 0.25s;
  display: flex;
  flex-direction: column;
  gap: 10px;
  position: relative;
  overflow: hidden;
}
.subject-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
  background: var(--card-color, var(--accent));
  transition: height 0.2s;
}
.subject-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--card-color, var(--accent)); }
.subject-card:hover::before { height: 8px; }
.subject-icon { font-size: 38px; }
.subject-title { font-weight: 800; font-size: 18px; }
.subject-desc { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
.subject-tag {
  font-size: 12px;
  font-weight: 700;
  color: var(--card-color, var(--accent));
  background: color-mix(in srgb, var(--card-color, var(--accent)) 12%, transparent);
  padding: 3px 10px;
  border-radius: 20px;
  width: fit-content;
}

/* Self-learning card special */
.subject-card.sandbox-card {
  border-style: dashed;
  border-width: 2.5px;
  background: var(--accent-light);
}

/* scroll reveal */
.scroll-reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.45s ease, transform 0.45s ease; }
.scroll-reveal.visible { opacity: 1; transform: none; }

/* =============================================
   LESSON LAYOUT
============================================= */
.lesson-layout {
  display: grid;
  grid-template-columns: 264px 1fr;
  max-width: 1200px;
  margin: 0 auto;
  min-height: calc(100vh - var(--nav-h) - 5px);
  transition: grid-template-columns 0.3s;
}

.lesson-sidebar {
  background: var(--surface);
  border-right: 2px solid var(--border);
  padding: 22px 14px;
  position: sticky;
  top: calc(var(--nav-h) + 5px);
  height: calc(100vh - var(--nav-h) - 5px);
  overflow-y: auto;
  transition: background 0.4s;
}

.lesson-sidebar h3 {
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 12px;
  padding: 0 8px;
}

.chapter-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  color: var(--text-muted);
  transition: all 0.18s;
  margin-bottom: 3px;
}
.chapter-item:hover { background: var(--surface2); color: var(--text); }
.chapter-item.active { background: var(--accent-light); color: var(--accent); }
.chapter-item.done { color: var(--success); }

.check-circle {
  width: 20px; height: 20px;
  border-radius: 50%;
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  flex-shrink: 0;
  transition: all 0.2s;
}
.chapter-item.done .check-circle { background: var(--success); border-color: var(--success); color: white; }
.chapter-item.active .check-circle { border-color: var(--accent); }

/* =============================================
   LESSON CONTENT
============================================= */
.lesson-content { padding: 28px 32px; transition: all 0.3s; }

.lesson-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 20px;
  gap: 16px;
}

.lesson-title-area h2 {
  font-size: clamp(20px, 3vw, 28px);
  font-weight: 800;
  margin-bottom: 8px;
}

.lesson-meta { display: flex; gap: 10px; flex-wrap: wrap; }
.lesson-tag {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  font-weight: 600;
  color: var(--text-muted);
}

.lesson-actions { display: flex; gap: 7px; flex-wrap: wrap; }
.tool-btn {
  background: var(--surface2);
  border: 1.5px solid var(--border);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 700;
