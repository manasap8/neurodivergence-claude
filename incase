async function sendChat(){
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if(!msg) return;

  const messages = document.getElementById('chatMessages');

  const userMsg = document.createElement('div');
  userMsg.className = 'msg user';
  userMsg.textContent = msg;
  messages.appendChild(userMsg);

  const thinkMsg = document.createElement('div');
  thinkMsg.className = 'msg bot thinking';
  thinkMsg.textContent = '🤔 Thinking...';
  messages.appendChild(thinkMsg);

  input.value = '';
  messages.scrollTop = messages.scrollHeight;

  await new Promise(r=>setTimeout(r,600));
  thinkMsg.remove();

  const lower = msg.toLowerCase();
  let response = '';

  // 1. Search current lesson chunks
  if(state.lessonData && state.lessonData.chunks){
    for(const chunk of state.lessonData.chunks){
      const plain = chunk.text.replace(/<[^>]+>/g,'');
      const words = lower.replace(/\b(what|is|are|how|why|explain|tell me|about|the|a|an)\b/g,'').trim();
      if(words.length>2 && plain.toLowerCase().includes(words.split(' ')[0])){
        response = `📖 From the current lesson: ${plain.substring(0,180)}...`;
        break;
      }
    }
  }

  // 2. Knowledge base
  if(!response){
    for(const [key,val] of Object.entries(BOT_KB)){
      if(lower.includes(key)){ response=val; break; }
    }
  }

  // 3. Default
  if(!response) response = BOT_KB.default;

  // 4. Simplify prefix
  if(lower.includes('simpl')||lower.includes('easy')||lower.includes('eli5')){
    response = '🧒 In simple terms: '+response;
  }

  const botMsg = document.createElement('div');
  botMsg.className = 'msg bot';
  botMsg.textContent = response;
  messages.appendChild(botMsg);
  messages.scrollTop = messages.scrollHeight;
}

