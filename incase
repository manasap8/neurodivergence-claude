/* Fix streak on load */
(function checkStreak(){
  const today = new Date().toDateString();
  if (state.lastStudyDate !== today) {
    const yesterday = new Date();
    yesterday.setDate(yesterday.getDate()-1);
    if (state.lastStudyDate !== yesterday.toDateString()) {
      if (state.lastStudyDate) state.streak = 0; // broke streak
    }
  }
})();

function saveState(){
  const s = {...state};
  delete s.lessonData; delete s.quizAnswers; delete s.pomoTimerID;
  localStorage.setItem('nl_state', JSON.stringify(s));
}

